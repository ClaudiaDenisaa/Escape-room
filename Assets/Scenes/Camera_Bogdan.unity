  m_Name: 
  m_EditorClassIdentifier: 
  questions:
  - question: "Cine conducea de obicei un regat \xEEn Evul Mediu?"
    answers:
    - Regele
    - Fermierul
    - Negustorul
    - Pescarul
    correctIndex: 0
  - question: "Ce purtau cavalerii pentru protec\u021Bie \xEEn lupt\u0103?"
    answers:
    - "Armur\u0103"
    - "Pelerin\u0103 magic\u0103"
    - "Costum din m\u0103tase"
    - "Rochie regal\u0103"
    correctIndex: 0
  - question: "Ce simboliza coroana \xEEn Evul Mediu?"
    answers:
    - "Distrac\u021Bia"
    - "Conducerea regal\u0103"
    - "Comer\u021Bul"
    - Agricultura
    correctIndex: 1
  - question: "Pe ce se scriau adesea documentele \xEEn Evul Mediu?"
    answers:
    - Plastic
    - Pergament
    - Tablete electronice
    - "Sticl\u0103"
    correctIndex: 1
  - question: Care era una dintre armele importante din Evul Mediu?
    answers:
    - Ceasul
    - Telefonul
    - Sabia
    - Binoclul
    correctIndex: 2
